{
  "name": "differ-monorepo",
  "private": true,
  "version": "0.0.0",
  "author": "Alex Powell",
  "license": "SEE LICENSE IN LICENSE",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run tauri dev -w apps/desktop",
    "dev:web": "npm run dev -w apps/web",
    "build:desktop": "npm run build -w apps/desktop",
    "build:web": "npm run build -w apps/web",
    "tauri": "npm run tauri -w apps/desktop --",
    "lint": "npm run lint -w apps/desktop && npm run lint -w apps/web",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "prettier": "^3.8.4"
  }
}
